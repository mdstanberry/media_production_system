# .env.example
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to Git — it is excluded by .gitignore.

# Notion Integration Token
# Used by Make to read from and write to your Notion workspace (Idea Registry, Media Pipeline).
# Obtain from: https://www.notion.so/my-integrations → Create New Integration → copy the Internal Integration Token
NOTION_API_KEY=

# Perplexity API Key
# Used by the Make scenario to call the Perplexity Sonar API for automated SEO research (Stage 0.2).
# Obtain from: https://www.perplexity.ai/settings/api → Generate → copy the API key
PERPLEXITY_API_KEY=
