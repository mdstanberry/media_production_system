# Environment variables
.env
.env.local
.env.*.local
*.env                    # catches any environment file variant (e.g. production.env, test.env)

# Local video project folders
# Video files are too large for Git and are managed locally — only the _PROJECT_TEMPLATE is tracked
projects/[0-9]*/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next/
.nuxt/
dist/

# IDE and editor files
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Test coverage
coverage/
.coverage
htmlcov/

# Build artifacts
*.pyc
*.pyo
